---
import figtreeFontUrl from "@fontsource-variable/figtree/files/figtree-latin-wght-normal.woff2?url";
import frauncesFontUrl from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";
import "@/src/styles/global.css";
import CafeCard from "@/src/components/CafeCard.astro";
import { areasByPopularity, cafesByNewest } from "@/src/lib/cafes";
import { SEO, structuredDataJson } from "@/src/lib/seo";

const GITHUB_URL = "https://github.com/amalshaji/cafeblr";
const ADD_CAFE_URL = `${GITHUB_URL}#add-a-cafe`;

const cafes = cafesByNewest;
const areas = areasByPopularity;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preload" href={figtreeFontUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={frauncesFontUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={SEO.themeColor} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={SEO.canonicalUrl} />
    <title>{SEO.title}</title>
    <meta name="description" content={SEO.description} />
    <meta property="og:site_name" content={SEO.siteName} />
    <meta property="og:title" content={SEO.title} />
    <meta property="og:description" content={SEO.description} />
    <meta property="og:url" content={SEO.canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={SEO.locale} />
    <meta property="og:image" content={SEO.ogImageUrl} />
    <meta property="og:image:width" content={String(SEO.ogImageWidth)} />
    <meta property="og:image:height" content={String(SEO.ogImageHeight)} />
    <meta property="og:image:alt" content={SEO.ogImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={SEO.title} />
    <meta name="twitter:description" content={SEO.description} />
    <meta name="twitter:image" content={SEO.ogImageUrl} />
    <meta name="twitter:image:alt" content={SEO.ogImageAlt} />
    <script type="application/ld+json" set:html={structuredDataJson}></script>
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href="/" class="wordmark">
          <img src="/favicon.svg" alt="" width="24" height="24" />
          <span>Cafe <em>BLR</em></span>
        </a>
        <label class="search">
          <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <circle cx="7" cy="7" r="5"></circle>
            <path d="M11 11l3.5 3.5"></path>
          </svg>
          <input
            id="search"
            type="search"
            placeholder="Search cafes, areas, vibes…"
            autocomplete="off"
            aria-label="Search cafes"
          />
        </label>
        <a class="add-link" href={ADD_CAFE_URL} target="_blank" rel="noopener">+ Add a cafe</a>
      </div>
    </header>

    <main class="wrap">
      <section class="intro">
        <h1>Nice cafes in Bengaluru, found by the internet.</h1>
        <p>
          Every spot here comes from a post people actually loved. Tap the heart for the
          receipts, or get directions and go.
        </p>
        <aside class="definition">
          <p class="def-head">
            <dfn>ca·fé</dfn>
            <span class="phonetic">/ˈka·feɪ/</span>
            <span class="pos">noun</span>
          </p>
          <p class="def-body">“a small restaurant that serves drinks and light meals.”</p>
          <p class="def-source">— Google. So yes, the dosa places count.</p>
        </aside>
      </section>

      <section class="browse-tools" aria-label="Browse cafes">
        <nav class="chip-rail" aria-label="Filter by area">
          <button class="chip" data-area="" aria-pressed="true">
            All <span class="n">{cafes.length}</span>
          </button>
          {
            areas.map(([area, count]) => (
              <button class="chip" data-area={area} aria-pressed="false">
                {area} <span class="n">{count}</span>
              </button>
            ))
          }
        </nav>
        <div class="browse-meta">
          <div class="sort-tools">
            <label>
              Sort
              <select id="sort">
                <option value="newest">Newest</option>
                <option value="liked">Most liked</option>
                <option value="area">Area</option>
                <option value="random">Random</option>
              </select>
            </label>
            <button class="clear-filters" id="clear-filters" type="button" hidden>Clear filters</button>
          </div>
          <p class="result-count" id="result-count" aria-live="polite">Showing {cafes.length} cafes</p>
        </div>
      </section>

      <section class="grid" id="grid" aria-live="polite">
        {cafes.map((cafe, i) => <CafeCard cafe={cafe} index={i} />)}
      </section>

      <div class="empty" id="empty" hidden>
        <strong>No cafes match that.</strong>
        Know a spot the internet loves? <a href={ADD_CAFE_URL} target="_blank" rel="noopener">Add it via a pull request</a>.
      </div>
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>
          Every cafe here earned its spot — sourced from posts Bengaluru loved.
          Add one via a&nbsp;<a href={ADD_CAFE_URL} target="_blank" rel="noopener">pull request</a>.
        </span>
        <span>Photos belong to their posters on X. Each card links to the original post.</span>
      </div>
    </footer>

    <script>
      const input = document.getElementById("search") as HTMLInputElement;
      const sort = document.getElementById("sort") as HTMLSelectElement;
      const chips = [...document.querySelectorAll<HTMLButtonElement>(".chip")];
      const grid = document.getElementById("grid")!;
      const cards = [...document.querySelectorAll<HTMLElement>(".card")];
      const empty = document.getElementById("empty")!;
      const resultCount = document.getElementById("result-count")!;
      const clearFilters = document.getElementById("clear-filters") as HTMLButtonElement;
      let activeArea = "";

      const validAreas = new Set(chips.map((chip) => chip.dataset.area ?? ""));
      const validSorts = new Set([...sort.options].map((option) => option.value));
      const params = new URLSearchParams(window.location.search);
      const areaParam = params.get("area") ?? "";
      const sortParam = params.get("sort") ?? "newest";

      input.value = params.get("q") ?? "";
      activeArea = validAreas.has(areaParam) ? areaParam : "";
      sort.value = validSorts.has(sortParam) ? sortParam : "newest";

      function syncChips() {
        for (const chip of chips) {
          chip.setAttribute("aria-pressed", String((chip.dataset.area ?? "") === activeArea));
        }
      }

      function syncUrl() {
        const next = new URLSearchParams();
        const q = input.value.trim();
        if (q) next.set("q", q);
        if (activeArea) next.set("area", activeArea);
        if (sort.value !== "newest") next.set("sort", sort.value);
        const query = next.toString();
        history.replaceState(null, "", query ? `?${query}` : window.location.pathname);
      }

      function sortCards() {
        const ordered = [...cards];
        if (sort.value === "liked") {
          ordered.sort((a, b) => Number(b.dataset.likes) - Number(a.dataset.likes));
        } else if (sort.value === "area") {
          ordered.sort(
            (a, b) =>
              a.dataset.area!.localeCompare(b.dataset.area!) ||
              Number(b.dataset.id) - Number(a.dataset.id),
          );
        } else if (sort.value === "random") {
          ordered.sort(() => Math.random() - 0.5);
        } else {
          ordered.sort((a, b) => Number(b.dataset.id) - Number(a.dataset.id));
        }
        for (const card of ordered) grid.append(card);
      }

      function cardMatches(card: HTMLElement, query: string): boolean {
        return (
          (!query || card.dataset.search!.includes(query)) &&
          (!activeArea || card.dataset.area === activeArea)
        );
      }

      function renderCards(query: string): number {
        let visible = 0;
        for (const card of cards) {
          const match = cardMatches(card, query);
          card.hidden = !match;
          if (match) visible++;
        }
        return visible;
      }

      function renderBrowseState(visible: number, query: string) {
        resultCount.textContent = `Showing ${visible} ${visible === 1 ? "cafe" : "cafes"}`;
        empty.hidden = visible !== 0 || cards.length === 0;
        clearFilters.hidden = !query && !activeArea && sort.value === "newest";
      }

      function apply() {
        const query = input.value.trim().toLowerCase();
        const visible = renderCards(query);
        renderBrowseState(visible, query);
        syncUrl();
      }

      input.addEventListener("input", apply);
      sort.addEventListener("change", () => {
        sortCards();
        apply();
      });
      clearFilters.addEventListener("click", () => {
        input.value = "";
        activeArea = "";
        sort.value = "newest";
        syncChips();
        sortCards();
        apply();
        input.focus();
      });

      for (const chip of chips) {
        chip.addEventListener("click", () => {
          activeArea = chip.dataset.area ?? "";
          syncChips();
          apply();
        });
      }

      syncChips();
      sortCards();
      apply();
    </script>
  </body>
</html>
